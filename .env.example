# ── Database ──────────────────────────────────────────────────────────────────
OMNIGRAPH_DB_HOST=localhost
OMNIGRAPH_DB_PORT=5432
OMNIGRAPH_DB_NAME=omnigraph
OMNIGRAPH_DB_USER=postgres
OMNIGRAPH_DB_PASSWORD=postgres

# ── AI Services ───────────────────────────────────────────────────────────────
# Required for agentic RAG + LLM-powered entity extraction
ANTHROPIC_API_KEY=sk-ant-...

# Required for semantic/vector search
VOYAGE_API_KEY=pa-...

# ── API Security ──────────────────────────────────────────────────────────────
# API key required in X-API-Key header for all /api/v1/* endpoints.
# Leave empty to disable auth (development only).
OMNIGRAPH_API_KEY=changeme
