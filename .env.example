# Copy to .env and fill in the two required keys. Every value maps to a field in
# data_spear/config.py; uncommented lines show the defaults.

# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Pinecone API key — https://www.pinecone.io/  (retrieval is optional; the agent
# works without ingested context, but the server needs a valid key to start.)
PINECONE_API_KEY=your_pinecone_api_key

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Fallback DSN used when the CLI's `connect` hasn't supplied one at runtime.
# Tip: point Data-Spear at a least-privilege (read-mostly) role — writes are gated
# in-app, but a restricted grant is the real safety boundary.
PG_DSN=postgresql://user:password@localhost:5432/database

# ── Anthropic (optional) ──────────────────────────────────────────────────────
# ANSWER_MODEL=claude-opus-4-8
# ANSWER_MAX_TOKENS=2048          # max output tokens per agent turn
# MAX_AGENT_TURNS=12              # hard cap on agent-loop turns

# ── Pinecone (optional) ───────────────────────────────────────────────────────
# PINECONE_INDEX=data-spear
# PINECONE_CLOUD=aws
# PINECONE_REGION=us-east-1
# EMBEDDING_MODEL=llama-text-embed-v2

# ── Retrieval (optional) ──────────────────────────────────────────────────────
# TOP_K=6

# ── API service (optional) ────────────────────────────────────────────────────
# When set, every endpoint except /healthz requires `Authorization: Bearer <token>`.
# API_TOKEN=

# Per-statement SQL timeout, in milliseconds.
# STATEMENT_TIMEOUT_MS=30000
