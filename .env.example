# ── Database ──────────────────────────────────────────────────────────────────
OMNIGRAPH_DB_HOST=localhost
OMNIGRAPH_DB_PORT=5432
OMNIGRAPH_DB_NAME=omnigraph
OMNIGRAPH_DB_USER=postgres
OMNIGRAPH_DB_PASSWORD=postgres

# Connection pool size (tune to your workload)
OMNIGRAPH_DB_POOL_MIN=2
OMNIGRAPH_DB_POOL_MAX=10

# ── AI Services ───────────────────────────────────────────────────────────────
# Required for agentic RAG + LLM-powered entity extraction
ANTHROPIC_API_KEY=sk-ant-...

# Required for semantic/vector search
VOYAGE_API_KEY=pa-...

# ── REST API ──────────────────────────────────────────────────────────────────
# API key required in X-API-Key header for all /api/v1/* endpoints.
# Leave empty to disable auth (development only — UNSAFE in production).
OMNIGRAPH_API_KEY=changeme

# Comma-separated allowed CORS origins (default: * — restrict in production)
OMNIGRAPH_CORS_ORIGINS=https://your-frontend.example.com,http://localhost:3000

# Log level: DEBUG | INFO | WARNING | ERROR
OMNIGRAPH_LOG_LEVEL=INFO

# ── Docker ────────────────────────────────────────────────────────────────────
UVICORN_WORKERS=2
