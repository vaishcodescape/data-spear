{
  "_comment": "Add this block to ~/.claude/claude_desktop_config.json (Mac/Linux) or %APPDATA%\\Claude\\claude_desktop_config.json (Windows). Update 'cwd' to your absolute path.",
  "mcpServers": {
    "omnigraph": {
      "command": "python",
      "args": ["-m", "mcp_server.server"],
      "cwd": "/absolute/path/to/Omni-Graph",
      "env": {
        "ANTHROPIC_API_KEY": "sk-ant-...",
        "VOYAGE_API_KEY": "pa-...",
        "OMNIGRAPH_DB_HOST": "localhost",
        "OMNIGRAPH_DB_PORT": "5432",
        "OMNIGRAPH_DB_NAME": "omnigraph",
        "OMNIGRAPH_DB_USER": "postgres",
        "OMNIGRAPH_DB_PASSWORD": "postgres",
        "OMNIGRAPH_DEFAULT_USER_ID": "1"
      }
    }
  }
}
